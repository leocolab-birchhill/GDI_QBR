# ─────────────────────────────────────────────────────────────
# GDI QBR OS — Environment variables (TEMPLATE / PLACEHOLDERS ONLY)
# Copy to `.env` for local dev. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

APP_ENV=development
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
SECRET_KEY=change-me-in-prod

# Local dev: docker compose up -d, then:
DATABASE_URL=postgresql://qbr:qbr@localhost:5432/qbr?schema=public

# ── One-time Lakebase migrate from your laptop (do NOT use sqlite or fake URLs) ──
# 1. databricks auth login --host https://<workspace>.azuredatabricks.net
# 2. Lakebase → Connect → Parameters only — export (unset DATABASE_URL if it is sqlite/invalid):
#    PGHOST=ep-....database....databricks.com
#    PGDATABASE=databricks_postgres
#    LAKEBASE_ENDPOINT=projects/.../branches/.../endpoints/...
#    PGUSER=your.email@company.com
#    PGPORT=5432
#    PGSSLMODE=require
# 3. npm run db:migrate
# 4. export GRANT_APP_PGUSER="<app-service-principal-client-id>"  # Databricks Apps → your app → Client ID
# 5. npm run db:grant
# 6. npm run db:seed
#
# Temporary manual URL (OAuth token expires ~1 hour):
# postgresql://YOUR_EMAIL:OAUTH_TOKEN@PGHOST:5432/PGDATABASE?sslmode=require&schema=public

# OpenAI — extraction / classification / rewriting / drafting
OPENAI_API_KEY=sk-your-openai-key-placeholder
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium

# Storage: "local" for dev, "volume" on Databricks Apps
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
# UC_VOLUME_PATH=/Volumes/databricks_prd/default/br_ppt_storage  # set on Databricks via app.yaml

# Approved house deck used as the EXACT format example for the AI drafter.
QBR_TEMPLATE_PATH=./templates/qbr_brand_template.pptx

# Email provider. "mock" works fully offline via /api-test/email.
EMAIL_PROVIDER=mock
QBR_MAILBOX=QBR_Robot@outlook.com
EMAIL_SENDER_NAME=GDI QBR OS

# Microsoft Graph (optional). Required when EMAIL_PROVIDER=graph.
MICROSOFT_CLIENT_ID=your-client-id-placeholder
MICROSOFT_CLIENT_SECRET=your-client-secret-placeholder
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/outlook/callback
MICROSOFT_SCOPES=User.Read Mail.Send Mail.ReadWrite offline_access
OUTLOOK_POLL_INTERVAL_SECONDS=30
GRAPH_REFRESH_TOKEN=

# ── Databricks Apps (auto-injected in production — do not set locally) ──
# LAKEBASE_ENDPOINT=projects/.../branches/.../endpoints/...
# PGHOST=...
# DATABRICKS_CLIENT_ID=...
# DATABRICKS_APP_PORT=8000

# ── Databricks secret scope (create before deploy) ──
# databricks secrets create-scope gdi-qbr-os-secrets
# databricks secrets put-secret gdi-qbr-os-secrets OPENAI_API_KEY --string-value "..."
# databricks secrets put-secret gdi-qbr-os-secrets SECRET_KEY --string-value "..."
# databricks secrets put-secret gdi-qbr-os-secrets MICROSOFT_CLIENT_ID --string-value "..."
# databricks secrets put-secret gdi-qbr-os-secrets MICROSOFT_CLIENT_SECRET --string-value "..."
