# ─────────────────────────────────────────────────────────────
# GDI QBR OS — Environment variables (TEMPLATE / PLACEHOLDERS ONLY)
# Copy this file to `.env.local` and fill in real values:
#   cp env.example .env.local
# NEVER commit `.env`, `.env.local`, or real secrets.
# ─────────────────────────────────────────────────────────────

APP_ENV=development
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
SECRET_KEY=change-me-in-prod

# Local development uses SQLite. For Postgres (docker compose):
# DATABASE_URL=postgresql://qbr:qbr@localhost:5432/qbr?schema=public
DATABASE_URL=file:./dev.db

# OpenAI — extraction / classification / rewriting / drafting
# PLACEHOLDER ONLY. Put your real key in `.env` / `.env.local` (git-ignored).
OPENAI_API_KEY=sk-your-openai-key-placeholder
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium

# Storage backend for generated PPTs and attachments
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# Approved house deck used as the EXACT format example for the AI drafter.
# Its structure/content is extracted at runtime and fed to the model.
QBR_TEMPLATE_PATH=./templates/qbr_brand_template.pptx

# Email provider. "mock" works fully offline via /api-test/email.
# Set to "graph" to send/receive real email via Microsoft Graph.
# Options: mock | graph | sendgrid | mailgun | postmark
EMAIL_PROVIDER=graph
# The connected Graph mailbox sends as itself; set this to that address/alias.
QBR_MAILBOX=QBR_Robot@outlook.com
EMAIL_SENDER_NAME=GDI QBR OS

# Microsoft Graph. App works without these (falls back to mock).
# Personal Microsoft accounts (outlook.com) require delegated auth + tenant=common.
# PLACEHOLDERS ONLY — put real values in `.env` (git-ignored), not here.
MICROSOFT_CLIENT_ID=your-client-id-placeholder
MICROSOFT_CLIENT_SECRET=your-client-secret-placeholder
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/outlook/callback
MICROSOFT_SCOPES=User.Read Mail.Send Mail.ReadWrite offline_access
OUTLOOK_POLL_INTERVAL_SECONDS=30

# Optional: paste a stored refresh token here to auto-connect with zero clicks
# (even after a DB reset). Get it by running:  npm run graph:token
# Keep this secret — never commit it.
GRAPH_REFRESH_TOKEN=
