{
  "name": "gdi-qbr-os",
  "version": "0.1.0",
  "private": true,
  "description": "GDI BR Creation Agent - Email-first Quarterly Business Review creation agent",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--use-system-ca next dev",
    "dev:reset": "node scripts/dev-reset.mjs",
    "build": "NODE_OPTIONS=--use-system-ca prisma generate && NODE_OPTIONS=--use-system-ca next build",
    "build:local": "cross-env NODE_OPTIONS=--use-system-ca prisma generate && cross-env NODE_OPTIONS=--use-system-ca next build",
    "start": "NODE_OPTIONS=--use-system-ca next start -p ${DATABRICKS_APP_PORT:-8000} -H 0.0.0.0",
    "start:local": "node scripts/databricks-start.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:grant": "node scripts/db-grant-app.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:seed:local": "cross-env NODE_OPTIONS=--use-system-ca tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "cross-env NODE_OPTIONS=--use-system-ca prisma generate",
    "prisma:migrate": "cross-env NODE_OPTIONS=--use-system-ca prisma migrate dev",
    "prisma:deploy": "cross-env NODE_OPTIONS=--use-system-ca prisma migrate deploy",
    "prisma:reset": "cross-env NODE_OPTIONS=--use-system-ca prisma migrate reset --force",
    "graph:token": "cross-env NODE_OPTIONS=--use-system-ca tsx scripts/print-graph-token.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@databricks/lakebase": "^0.1.0",
    "@databricks/sdk-experimental": "^0.16.0",
    "@prisma/adapter-pg": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "openai": "^4.73.0",
    "pg": "^8.13.1",
    "postcss": "^8.5.16",
    "pptxgenjs": "^3.12.0",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.19",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
